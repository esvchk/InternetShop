<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-5.0.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1776874091510-1" author="esvchk">
        <createTable tableName="Customer">
            <column name="id" type="INT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_customer"/>
            </column>
            <column name="createDateTime" type="DATETIME"/>
            <column name="updateDateTime" type="DATETIME"/>
            <column name="login" type="VARCHAR(255)"/>
            <column name="passWord" type="VARCHAR(255)"/>
            <column name="email" type="VARCHAR(255)"/>
            <column name="payment" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>
    <changeSet id="1776874091510-2" author="esvchk">
        <createTable tableName="Operator">
            <column name="id" type="INT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_operator"/>
            </column>
            <column name="createDateTime" type="DATETIME"/>
            <column name="updateDateTime" type="DATETIME"/>
            <column name="login" type="VARCHAR(255)"/>
            <column name="passWord" type="VARCHAR(255)"/>
            <column name="accessLevel" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>
    <changeSet id="1776874091510-3" author="esvchk">
        <createTable tableName="Order">
            <column name="id" type="INT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_order"/>
            </column>
            <column name="createDateTime" type="DATETIME"/>
            <column name="updateDateTime" type="DATETIME"/>
            <column name="operator_id" type="INT"/>
        </createTable>
    </changeSet>
    <changeSet id="1776874091510-4" author="esvchk">
        <createTable tableName="Product">
            <column name="id" type="INT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_product"/>
            </column>
            <column name="createDateTime" type="DATETIME"/>
            <column name="updateDateTime" type="DATETIME"/>
            <column name="name" type="VARCHAR(255)"/>
            <column name="price" type="DOUBLE"/>
            <column name="info" type="VARCHAR(255)"/>
            <column name="manufacturer" type="VARCHAR(255)"/>
            <column name="bestBefore" type="DATE"/>
        </createTable>
    </changeSet>
    <changeSet id="1776874091510-5" author="esvchk">
        <createTable tableName="customer_orders">
            <column name="customer_id" type="INT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_customer_orders"/>
            </column>
            <column name="order_id" type="INT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_customer_orders"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1776874091510-6" author="esvchk">
        <createTable tableName="product_orders">
            <column name="order_id" type="INT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_product_orders"/>
            </column>
            <column name="product_id" type="INT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_product_orders"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1776874091510-7" author="esvchk">
        <addForeignKeyConstraint baseColumnNames="operator_id" baseTableName="Order"
                                 constraintName="FK_ORDER_ON_OPERATOR" referencedColumnNames="id"
                                 referencedTableName="Operator"/>
    </changeSet>
    <changeSet id="1776874091510-8" author="esvchk">
        <addForeignKeyConstraint baseColumnNames="customer_id" baseTableName="customer_orders"
                                 constraintName="fk_cusord_on_customer" referencedColumnNames="id"
                                 referencedTableName="Customer"/>
    </changeSet>
    <changeSet id="1776874091510-9" author="esvchk">
        <addForeignKeyConstraint baseColumnNames="order_id" baseTableName="customer_orders"
                                 constraintName="fk_cusord_on_order" referencedColumnNames="id"
                                 referencedTableName="Order"/>
    </changeSet>
    <changeSet id="1776874091510-10" author="esvchk">
        <addForeignKeyConstraint baseColumnNames="order_id" baseTableName="product_orders"
                                 constraintName="fk_proord_on_order" referencedColumnNames="id"
                                 referencedTableName="Order"/>
    </changeSet>
    <changeSet id="1776874091510-11" author="esvchk">
        <addForeignKeyConstraint baseColumnNames="product_id" baseTableName="product_orders"
                                 constraintName="fk_proord_on_product" referencedColumnNames="id"
                                 referencedTableName="Product"/>
    </changeSet>

</databaseChangeLog>