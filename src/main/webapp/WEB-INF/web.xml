<!DOCTYPE web-app PUBLIC
        "-//Sun Microsystems, Inc.//DTD Web Application 2.3//EN"
        "http://java.sun.com/dtd/web-app_2_3.dtd" >


<web-app>

    <display-name>Archetype Created Web Application</display-name>

    <servlet>
        <servlet-name>ShowProducts</servlet-name>
        <servlet-class>com.academy.course.controller.ShowProducts</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>AddProduct</servlet-name>
        <servlet-class>com.academy.course.controller.AddProduct</servlet-class>
    </servlet>

    <servlet>
    <servlet-name>FindProductById</servlet-name>
    <servlet-class>com.academy.course.controller.FindProductById</servlet-class>
</servlet>

    <servlet>
        <servlet-name>FindProductByName</servlet-name>
        <servlet-class>com.academy.course.controller.FindProductByName</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>UpdateProduct</servlet-name>
        <servlet-class>com.academy.course.controller.UpdateProduct</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>UpdateProduct</servlet-name>
        <url-pattern>/UpdateProduct</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>FindProductByName</servlet-name>
        <url-pattern>/FindProductByName</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>FindProductById</servlet-name>
        <url-pattern>/FindProductById</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>ShowProducts</servlet-name>
        <url-pattern>/ShowProducts</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>AddProduct</servlet-name>
        <url-pattern>/AddProduct</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>HelloPage.jsp</welcome-file>
    </welcome-file-list>

</web-app>
